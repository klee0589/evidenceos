{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "plan": {
      "type": "string",
      "enum": [
        "free",
        "pro"
      ],
      "default": "free",
      "title": "Subscription Plan"
    },
    "stripe_customer_id": {
      "type": "string",
      "title": "Stripe Customer ID"
    }
  }
}